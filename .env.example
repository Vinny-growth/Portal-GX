#--------------------------------------------------------------------
# EXEMPLO DE .env — plataforma white-label
#--------------------------------------------------------------------
# Copie para `.env` e preencha por INSTALL. NUNCA commite o `.env` real
# (ele é gitignored). Todos os valores abaixo são PLACEHOLDERS.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
# production | development
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
# URL base do install, COM barra final. Ex.: https://suamarca.com/
app.baseURL = 'https://__DOMINIO__/'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.username = "__DB_USER__"
database.default.password = "__DB_PASSWORD__"
database.default.database = "__DB_NAME__"
database.default.port = 3306

#--------------------------------------------------------------------
# LICENSE (Varient) — inerte: o app não valida estes campos.
# Mantidos por compatibilidade; podem ficar vazios.
#--------------------------------------------------------------------
PURCHASE_CODE = ''
LICENSE_KEY = ''

#--------------------------------------------------------------------
# COOKIE — prefixo único por marca ajuda a evitar colisão de cookies.
#--------------------------------------------------------------------
cookie.prefix = 'wl_'

#--------------------------------------------------------------------
# SIMULADORES / CORS
#--------------------------------------------------------------------
SIMULATOR_ALLOWED_ORIGINS="https://__DOMINIO__"

#--------------------------------------------------------------------
# CRM — captura de leads (opcional; depende de integração externa)
#--------------------------------------------------------------------
CRM_LEAD_ENDPOINT=""
CRM_LEAD_API_KEY=""
CRM_LEAD_ORIGIN=""
CRM_LEAD_TIMEOUT=10
CRM_LEAD_SOURCE_SYSTEM=""
CRM_LEAD_STATUS="novo"
CRM_LEAD_ASSIGNED_TO=""
LEAD_DEDUP_MINUTES=60

#--------------------------------------------------------------------
# OpenAI (geração de conteúdo e imagens) — opcional
#--------------------------------------------------------------------
OPENAI_API_KEY=""
OPENAI_DEFAULT_MODEL="gpt-image-1-mini"
OPENAI_DEFAULT_SIZE=1024x1536
OPENAI_DEFAULT_QUALITY=high
OPENAI_IMAGE_TIMEOUT="150"
OPENAI_TEXT_MODEL="gpt-5.4-mini"
OPENAI_TEXT_FALLBACK_MODEL="gpt-4.1-mini"
OPENAI_TEXT_TIMEOUT="60"

#--------------------------------------------------------------------
# Grok / X.ai (X-Pulse) — opcional
#--------------------------------------------------------------------
GROK_API_KEY=""

#--------------------------------------------------------------------
# CRM Newsletter sync — opcional
#--------------------------------------------------------------------
CRM_NEWSLETTER_LEADS_ENDPOINT=""
CRM_NEWSLETTER_CLIENTS_ENDPOINT=""
CRM_NEWSLETTER_ANON_KEY=""
CRM_NEWSLETTER_PER_PAGE="200"
CRM_NEWSLETTER_TIMEOUT="30"

#--------------------------------------------------------------------
# SEO Analysis (painel admin) — opcional
#--------------------------------------------------------------------
# GSC_SITE_URL: "sc-domain:suamarca.com" ou "https://suamarca.com/".
GSC_SITE_URL="sc-domain:__DOMINIO__"
# Caminho ABSOLUTO por install do JSON da service account do Google.
# Deve ficar DENTRO do open_basedir (ex.: writable/private/gsc/…).
GSC_SERVICE_ACCOUNT_JSON="__ROOT_ABSOLUTO__/writable/private/gsc/service-account.json"
OPENSERP_ENABLED="false"
OPENSERP_URL="http://127.0.0.1:7000"
OPENSERP_ENGINE="google"
OPENSERP_PROXY_URL=""
SEO_TARGET_DOMAIN="__DOMINIO__"

#--------------------------------------------------------------------
# GitHub push (dev only — usado por do_push.sh). Opcional.
#--------------------------------------------------------------------
GITHUB_PUSH_USERNAME=""
GITHUB_PUSH_TOKEN=""

#--------------------------------------------------------------------
# PAGAMENTOS (módulo de cursos — Fase 4). Placeholders para o futuro.
# Gateways: MercadoPago (BR/MX) e Stripe (global).
#--------------------------------------------------------------------
# PAYMENT_GATEWAY="mercadopago"   # mercadopago | stripe
# MERCADOPAGO_ACCESS_TOKEN=""
# MERCADOPAGO_WEBHOOK_SECRET=""
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
